# ───── LLM / 第三方中转站 ─────
# OpenAI 兼容的中转站 base_url（例如 https://your-relay.example.com/v1）
OPENAI_API_BASE=
OPENAI_API_KEY=

# 默认模型名（按中转站支持的模型填）
LUSTRE_MODEL=claude-sonnet-4-5
# Planner / Coder / Reviewer 也可分别覆盖
# LUSTRE_PLANNER_MODEL=
# LUSTRE_CODER_MODEL=
# LUSTRE_REVIEWER_MODEL=

# ───── 运行时 ─────
# 会话持久化存储目录
LUSTRE_DATA_DIR=.lustre
# Reviewer 最大重试次数
LUSTRE_MAX_REVIEW_LOOPS=3
# 日志级别：DEBUG / INFO / WARNING / ERROR
LUSTRE_LOG_LEVEL=INFO
